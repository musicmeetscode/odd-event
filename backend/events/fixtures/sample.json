        "fields": {
            "session": 1,
            "member": 4,
            "content": "How do I use `select_related` effectively?",
            "created_at": "2024-10-26T10:05:00Z",
            "is_answered": true,
            "answer_text": "Great question! `select_related` is for foreign keys and one-to-one fields. It creates a SQL JOIN and adds the related object's fields to the main query."
