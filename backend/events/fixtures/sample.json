    {
        "model": "qna_app.question",
        "pk": 2,
        "fields": {
            "session": 1,
            "member": 5,
            "content": "What is the difference between `annotate` and `aggregate`?",
            "created_at": "2024-10-26T10:10:00Z",
            "is_answered": true,
            "answer_text": "`aggregate()` returns a single dictionary of values for the whole queryset. `annotate()` adds a new field with the aggregated value to each object in the queryset."
        }
